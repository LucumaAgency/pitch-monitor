{
  "name": "pitch-monitor",
  "version": "1.0.0",
  "description": "🎵 Web app para detectar notas musicales del micrófono y compararlas con videos de YouTube",
  "main": "server.cjs",
  "scripts": {
    "start": "node server.cjs",
    "dev": "nodemon server.cjs",
    "build": "node build.js && node setup-frontend.js",
    "build:frontend": "node build.js",
    "logs": "tail -f logs/debug.log",
    "logs:error": "tail -f logs/error.log",
    "test": "node --check server.cjs && echo \"syntax OK\"",
    "postinstall": "node build.js && node setup-frontend.js"
  },
  "keywords": [
    "pitch-detection",
    "audio-analysis",
    "web-audio-api",
    "youtube",
    "music"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "fluent-ffmpeg": "^2.1.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
